# ─── Base de datos ───────────────────────────────────────────────────────────
# Local:      file:./prisma/dev.db
# Producción: file:/app/prisma/prod.db   (Railway monta el volumen en /app/prisma/)
DATABASE_URL="file:./prisma/dev.db"

# ─── Autenticación JWT ────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Header requerido en /api/cron/*: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="amarilo-cron-2026-prod"

# ─── Google (Gmail + Sheets + Drive) ─────────────────────────────────────────
# Estas credenciales se configuran desde la UI en /dashboard/settings.
# No se requieren como variables de entorno; se guardan en la base de datos.
# Documentadas aquí solo como referencia de qué datos solicita la UI:
#
#   Gmail OAuth:
#     - Client ID
#     - Client Secret
#     - Refresh Token
#     - Email address
#
#   Google Service Account (Sheets + Drive):
#     - Client Email
#     - Private Key
#     - Drive Folder ID
